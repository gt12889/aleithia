# Modal backend URL — points to deployed Aleithia API
VITE_MODAL_URL=https://ibsrinivas27--alethia-serve.modal.run

# Optional backend URL for backend-owned routes when the frontend is deployed
# against a real FastAPI backend. Leave unset for local dev; set this before
# any deployed frontend is expected to use routes moved off Modal.
# VITE_BACKEND_URL=http://localhost:8000/api/data

# Optional Vite dev-server proxy target for local/frontend container setups.
# Host-based local dev defaults to http://localhost:8000.
# ALEITHIA_DEV_BACKEND_PROXY_TARGET=http://backend:8000
