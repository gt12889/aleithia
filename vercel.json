{
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "build": {
    "env": {
      "VITE_MODAL_URL": "https://gt12889--alethia-serve.modal.run"
    }
  },
  "rewrites": [
    {
      "source": "/api/data/:path*",
      "destination": "https://gt12889--alethia-serve.modal.run/api/data/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
